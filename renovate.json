{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "minimumReleaseAge": "7 days",
  "github-actions": {
    "enabled": true,
    "pinDigests": true
  },
  "includePaths": [
    "package.json",
    "package-lock.json",
    ".github/workflows/**"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "npm"
      ],
      "matchDepTypes": [
        "devDependencies"
      ],
      "groupName": "dev dependencies",
      "commitMessageTopic": "dev dependencies"
    }
  ],
  "labels": [
    "dependencies"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 4am on the first day of the month"
    ]
  }
}
